---
---
<div id="recurrent-modal" class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-[rgba(0,0,0,0.8)] backdrop-blur-sm hidden">
    <div class="bg-[#0f1011] w-full max-w-xl rounded-2xl border border-[rgba(255,255,255,0.1)] shadow-2xl animate-in fade-in zoom-in duration-200">
        <div class="px-6 py-4 border-b border-[rgba(255,255,255,0.05)] flex items-center justify-between">
            <h3 class="text-lg font-[510] text-[#f7f8f8]" id="modal-title">Add Recurrent Payment</h3>
            <button id="close-modal" class="text-[#8a8f98] hover:text-[#f7f8f8] transition-colors p-1">
                <i class="fas fa-times"></i>
            </button>
        </div>
        
        <form id="recurrent-form" class="p-6 space-y-5">
            <input type="hidden" name="id" id="recurrent-id" />
            <div class="space-y-2">
                <label class="text-[12px] font-bold text-[#62666d] uppercase tracking-wider">Title</label>
                <input type="text" id="title" name="title" required placeholder="Rent, Salary, etc." 
                    class="w-full bg-[rgba(255,255,255,0.03)] border border-[rgba(255,255,255,0.08)] rounded-lg px-4 py-2.5 text-[#f7f8f8] focus:border-[#5e6ad2] focus:ring-1 focus:ring-[#5e6ad2] outline-none transition-all" />
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-2">
                    <label class="text-[12px] font-bold text-[#62666d] uppercase tracking-wider">Amount</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-[#62666d]">$</span>
                        <input type="number" id="amount" name="amount" step="0.01" required placeholder="0.00" 
                            class="w-full bg-[rgba(255,255,255,0.03)] border border-[rgba(255,255,255,0.08)] rounded-lg pl-8 pr-4 py-2.5 text-[#f7f8f8] focus:border-[#5e6ad2] focus:ring-1 focus:ring-[#5e6ad2] outline-none transition-all" />
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="text-[12px] font-bold text-[#62666d] uppercase tracking-wider">Type</label>
                    <div class="flex gap-2 p-1 bg-[rgba(255,255,255,0.03)] rounded-lg border border-[rgba(255,255,255,0.08)]">
                        <label class="flex-1 cursor-pointer">
                            <input type="radio" name="type" value="expense" checked class="sr-only peer" />
                            <div class="text-center py-1.5 rounded-md text-[13px] font-[510] text-[#8a8f98] peer-checked:bg-[rgba(248,113,113,0.1)] peer-checked:text-[#f87171] transition-all">Expense</div>
                        </label>
                        <label class="flex-1 cursor-pointer">
                            <input type="radio" name="type" value="income" class="sr-only peer" />
                            <div class="text-center py-1.5 rounded-md text-[13px] font-[510] text-[#8a8f98] peer-checked:bg-[rgba(16,185,129,0.1)] peer-checked:text-[#10b981] transition-all">Income</div>
                        </label>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-2">
                    <label class="text-[12px] font-bold text-[#62666d] uppercase tracking-wider">Frequency</label>
                    <select id="frequency" name="frequency" required class="w-full bg-[rgba(255,255,255,0.03)] border border-[rgba(255,255,255,0.08)] rounded-lg px-4 py-2.5 text-[#f7f8f8] focus:border-[#5e6ad2] outline-none appearance-none">
                        <option value="daily">Daily</option>
                        <option value="weekly">Weekly</option>
                        <option value="monthly" selected>Monthly</option>
                        <option value="yearly">Yearly</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="text-[12px] font-bold text-[#62666d] uppercase tracking-wider">Start Date</label>
                    <input type="date" name="start_date" id="start_date" required 
                        class="w-full bg-[rgba(255,255,255,0.03)] border border-[rgba(255,255,255,0.08)] rounded-lg px-4 py-2.5 text-[#f7f8f8] focus:border-[#5e6ad2] outline-none" />
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-2 relative">
                    <label class="text-[12px] font-bold text-[#62666d] uppercase tracking-wider">Account</label>
                    <input type="hidden" name="account_id" id="account_id" required />
                    <button type="button" id="account-select-trigger" class="w-full bg-[rgba(255,255,255,0.03)] border border-[rgba(255,255,255,0.08)] rounded-lg px-4 py-2.5 text-left text-[14px] flex items-center justify-between transition-all">
                        <span id="selected-account-label" class="text-[#8a8f98]">Select Account</span>
                        <i class="fas fa-chevron-down text-[10px] text-[#62666d]"></i>
                    </button>
                    <div id="account-dropdown" class="absolute z-[110] left-0 right-0 mt-1 bg-[#0f1011] border border-[rgba(255,255,255,0.1)] rounded-lg shadow-2xl p-2 hidden">
                        <div id="account-options" class="max-h-48 overflow-y-auto space-y-1"></div>
                    </div>
                </div>
                <div class="space-y-2 relative">
                    <label class="text-[12px] font-bold text-[#62666d] uppercase tracking-wider">Category</label>
                    <input type="hidden" name="category_id" id="category_id" required />
                    <button type="button" id="category-select-trigger" disabled class="w-full bg-[rgba(255,255,255,0.03)] border border-[rgba(255,255,255,0.08)] rounded-lg px-4 py-2.5 text-left text-[14px] flex items-center justify-between transition-all disabled:opacity-50">
                        <span id="selected-category-label" class="text-[#8a8f98]">Select a type first</span>
                        <i class="fas fa-chevron-down text-[10px] text-[#62666d]"></i>
                    </button>
                    <div id="category-dropdown" class="absolute z-[110] left-0 right-0 mt-1 bg-[#0f1011] border border-[rgba(255,255,255,0.1)] rounded-lg shadow-2xl p-2 hidden">
                        <div id="category-options" class="max-h-48 overflow-y-auto space-y-1"></div>
                    </div>
                </div>
            </div>

            <div class="flex items-center gap-3 py-2">
                <input type="checkbox" name="is_active" id="is_active" value="1" checked class="w-4 h-4 rounded border-[rgba(255,255,255,0.1)] bg-[rgba(255,255,255,0.03)] text-[#5e6ad2] focus:ring-[#5e6ad2]" />
                <label for="is_active" class="text-[13px] text-[#8a8f98]">Active (enabled)</label>
            </div>

            <div class="flex gap-3 pt-4 border-t border-[rgba(255,255,255,0.05)]">
                <button type="button" id="delete-recurrent-btn" class="btn-secondary text-rose-500 hover:bg-rose-500/10 border-rose-500/20 hidden">Delete</button>
                <div class="flex-1"></div>
                <button type="button" id="cancel-modal" class="btn-secondary">Cancel</button>
                <button type="submit" class="btn-primary">Save Payment</button>
            </div>
        </form>
    </div>
</div>
