---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Categories">
    <main class="max-w-7xl mx-auto px-6 py-12">
        <!-- Header -->
        <header class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <h1 class="display-lg text-[#f7f8f8]">Categories</h1>
                <p class="text-[18px] text-[#8a8f98] mt-2 font-[400]">Organize your transactions with custom categories.</p>
            </div>
            <div class="flex gap-3">
                <button class="btn-primary" id="add-category-btn">
                    <i class="fas fa-plus mr-2 text-[10px]"></i> Add Category
                </button>
            </div>
        </header>

        <!-- Income Categories Section -->
        <section class="mb-12">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center border border-[rgba(255,255,255,0.08)] bg-[rgba(16,185,129,0.1)]">
                    <i class="fas fa-arrow-up text-[12px] text-[#10b981]"></i>
                </div>
                <h2 class="text-[20px] font-[590] text-[#f7f8f8] tracking-tight">Income</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="income-grid"></div>
        </section>

        <!-- Expense Categories Section -->
        <section>
            <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center border border-[rgba(255,255,255,0.08)] bg-[rgba(244,63,94,0.1)]">
                    <i class="fas fa-arrow-down text-[12px] text-[#f43f5e]"></i>
                </div>
                <h2 class="text-[20px] font-[590] text-[#f7f8f8] tracking-tight">Expenses</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="expense-grid"></div>
        </section>

        <!-- Global Loading State -->
        <div id="global-loading" class="py-24 text-center">
            <div class="inline-block animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-[#5e6ad2] mb-4"></div>
            <p class="text-[#8a8f98] font-[510]">Loading categories...</p>
        </div>
    </main>

    <!-- Category Modal -->
    <div id="category-modal" class="fixed inset-0 z-[100] hidden">
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
        <div class="absolute inset-0 flex items-center justify-center p-4">
            <div class="glass-card w-full max-w-md bg-[#0f1011] shadow-2xl animate-in fade-in zoom-in duration-200">
                <div class="p-6 border-b border-[rgba(255,255,255,0.05)] flex items-center justify-between">
                    <h2 class="text-xl font-[510] text-[#f7f8f8]" id="modal-title">Add Category</h2>
                    <button id="close-modal" class="text-[#8a8f98] hover:text-[#f7f8f8] transition-colors">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <form id="category-form" class="p-6 space-y-4">
                    <input type="hidden" id="category-id" name="id" />
                    <div>
                        <label for="name" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Category Name</label>
                        <input type="text" id="name" name="name" required
                            class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2 text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors"
                            placeholder="e.g. Food & Drinks" />
                    </div>
                    <div>
                        <label class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Type</label>
                        <div class="flex gap-4 items-center h-[42px]">
                            <label class="flex items-center gap-2 cursor-pointer group">
                                <input type="radio" name="type" value="expense" class="hidden peer" required>
                                <div class="w-4 h-4 rounded-full border border-[rgba(255,255,255,0.2)] peer-checked:border-[#5e6ad2] peer-checked:border-[5px] transition-all"></div>
                                <span class="text-[14px] text-[#8a8f98] group-hover:text-[#f7f8f8] transition-colors">Expense</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer group">
                                <input type="radio" name="type" value="income" class="hidden peer">
                                <div class="w-4 h-4 rounded-full border border-[rgba(255,255,255,0.2)] peer-checked:border-[#10b981] peer-checked:border-[5px] transition-all"></div>
                                <span class="text-[14px] text-[#8a8f98] group-hover:text-[#f7f8f8] transition-colors">Income</span>
                            </label>
                        </div>
                    </div>
                    <div>
                        <label for="color" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Color</label>
                        <div class="flex gap-3 items-center">
                            <input type="color" id="color" name="color" required
                                class="w-12 h-10 bg-transparent border-none cursor-pointer"
                                value="#5e6ad2" />
                            <input type="text" id="color-hex" 
                                class="flex-1 bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2 text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors"
                                placeholder="#5e6ad2" />
                        </div>
                    </div>
                    <div class="pt-4 flex gap-3">
                        <button type="button" id="delete-category-btn" class="hidden px-4 py-2 text-rose-500 hover:bg-rose-500/10 rounded-md text-sm font-[510] transition-colors mr-auto">
                            Delete
                        </button>
                        <button type="button" id="cancel-modal" class="btn-secondary">Cancel</button>
                        <button type="submit" class="btn-primary">Save Category</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        import type { Category } from "../types/category";

        const API_URL = import.meta.env.PUBLIC_API_URL; 

        let categoriesCache: Category[] | null = null;

        function getElements() {
            return {
                modal: document.getElementById('category-modal'),
                form: document.getElementById('category-form') as HTMLFormElement,
                modalTitle: document.getElementById('modal-title'),
                deleteBtn: document.getElementById('delete-category-btn'),
                addBtn: document.getElementById('add-category-btn'),
                closeBtn: document.getElementById('close-modal'),
                cancelBtn: document.getElementById('cancel-modal'),
                idInput: document.getElementById('category-id') as HTMLInputElement,
                nameInput: document.getElementById('name') as HTMLInputElement,
                colorInput: document.getElementById('color') as HTMLInputElement,
                colorHexInput: document.getElementById('color-hex') as HTMLInputElement,
            };
        }

        function openModal(category: Category | null = null) {
            const { modal, modalTitle, deleteBtn, form, idInput, nameInput, colorInput, colorHexInput } = getElements();
            if (!modal || !modalTitle || !deleteBtn || !form) return;

            if (category) {
                modalTitle.textContent = 'Edit Category';
                if (idInput) idInput.value = category.id.toString();
                if (nameInput) nameInput.value = category.name;
                if (colorInput) colorInput.value = category.color;
                if (colorHexInput) colorHexInput.value = category.color;
                
                // Set type radio
                const typeRadios = document.getElementsByName('type') as NodeListOf<HTMLInputElement>;
                typeRadios.forEach(r => {
                    if (r.value === category.type) r.checked = true;
                });

                deleteBtn.classList.remove('hidden');
            } else {
                modalTitle.textContent = 'Add Category';
                form.reset();
                if (idInput) idInput.value = '';
                if (colorInput) colorInput.value = '#5e6ad2';
                if (colorHexInput) colorHexInput.value = '#5e6ad2';
                deleteBtn.classList.add('hidden');
            }
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            const { modal } = getElements();
            if (modal) {
                modal.classList.add('hidden');
            }
            document.body.style.overflow = '';
        }

        async function saveCategory(e: SubmitEvent) {
            e.preventDefault();
            const { form } = getElements();
            if (!form) return;

            const formData = new FormData(form);
            const id = formData.get('id');
            const data = {
                name: formData.get('name'),
                type: formData.get('type'),
                color: formData.get('color'),
            };

            const url = id ? `${API_URL}/category/${id}` : `${API_URL}/category`;
            const method = id ? 'PUT' : 'POST';

            try {
                const response = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data),
                    credentials: 'include'
                });

                if (!response.ok) throw new Error('Failed to save category');
                
                categoriesCache = null;
                await init();
                closeModal();
            } catch (error) {
                console.error('Save error:', error);
                alert('Failed to save category');
            }
        }

        async function deleteCategory() {
            const { idInput } = getElements();
            const id = idInput?.value;
            if (!id || !confirm('Are you sure you want to delete this category?')) return;

            try {
                const response = await fetch(`${API_URL}/category/${id}`, {
                    method: 'DELETE',
                    credentials: 'include'
                });

                if (!response.ok) throw new Error('Failed to delete category');
                
                categoriesCache = null;
                await init();
                closeModal();
            } catch (error) {
                console.error('Delete error:', error);
                alert('Failed to delete category');
            }
        }

        function renderCategories(categories: Category[]) {
            const incomeGrid = document.getElementById('income-grid');
            const expenseGrid = document.getElementById('expense-grid');
            const loading = document.getElementById('global-loading');
            
            if (!incomeGrid || !expenseGrid) return;
            if (loading) loading.classList.add('hidden');
            
            incomeGrid.innerHTML = '';
            expenseGrid.innerHTML = '';

            const typeIcons: Record<string, string> = {
                expense: 'fa-arrow-down',
                income: 'fa-arrow-up'
            };

            categories.forEach((cat: Category) => {
                const grid = cat.type === 'income' ? incomeGrid : expenseGrid;
                const card = document.createElement('div');
                card.className = 'glass-card p-6 flex flex-col hover:border-[rgba(255,255,255,0.15)] transition-all group cursor-pointer';
                card.onclick = () => openModal(cat);
                
                const iconClass = typeIcons[cat.type] || 'fa-tag';

                card.innerHTML = `
                    <div class="flex items-start justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-lg flex items-center justify-center border border-[rgba(255,255,255,0.08)] bg-[rgba(255,255,255,0.03)] group-hover:bg-[rgba(255,255,255,0.05)] transition-colors" style="border-color: ${cat.color}33">
                                <i class="fas ${iconClass} text-[14px]" style="color: ${cat.color}"></i>
                            </div>
                            <div>
                                <h3 class="text-[16px] font-[510] text-[#f7f8f8] group-hover:text-[#828fff] transition-colors">${cat.name}</h3>
                                <div class="flex items-center gap-2 mt-0.5">
                                    <span class="text-[11px] text-[#62666d] uppercase tracking-wider font-[510]">${cat.type}</span>
                                    <div class="w-1 h-1 rounded-full bg-[#3e3e44]"></div>
                                    <span class="text-[11px] text-[#62666d]">${cat.color}</span>
                                </div>
                            </div>
                        </div>
                        <i class="fas fa-edit text-[10px] text-[#3e3e44] group-hover:text-[#8a8f98] transition-colors"></i>
                    </div>
                `;
                grid.appendChild(card);
            });

            // Handle empty states
            [incomeGrid, expenseGrid].forEach(grid => {
                if (grid.innerHTML === '') {
                    grid.innerHTML = `
                        <div class="col-span-full py-12 px-6 rounded-lg border border-dashed border-[rgba(255,255,255,0.05)] text-center">
                            <p class="text-[#62666d] text-[13px]">No categories found in this section.</p>
                        </div>
                    `;
                }
            });
        }

        async function init() {
            const loading = document.getElementById('global-loading');
            if (categoriesCache) {
                renderCategories(categoriesCache);
                return;
            }

            try {
                if (loading) loading.classList.remove('hidden');
                
                const response = await fetch(`${API_URL}/category`, {
                    credentials: 'include'
                });

                if (response.status === 401) {
                    window.location.href = '/login';
                    return;
                }

                if (!response.ok) throw new Error('Failed to fetch categories');

                const categoriesData: Category[] = await response.json();
                categoriesCache = categoriesData;
                renderCategories(categoriesData);
            } catch (error) {
                console.error('Fetch error:', error);
                const incomeGrid = document.getElementById('income-grid');
                if (incomeGrid && !categoriesCache) {
                    if (loading) loading.classList.add('hidden');
                    incomeGrid.innerHTML = `
                        <div class="col-span-full py-24 text-center">
                            <p class="text-rose-500 font-[510]">Error loading categories. Please try again later.</p>
                        </div>
                    `;
                }
            }
        }

        document.addEventListener('astro:page-load', () => {
            const { 
                addBtn, closeBtn, cancelBtn, form, deleteBtn, 
                colorInput, colorHexInput 
            } = getElements();

            init();

            colorInput?.addEventListener('input', (e) => {
                if (colorHexInput) colorHexInput.value = (e.target as HTMLInputElement).value;
            });

            colorHexInput?.addEventListener('input', (e) => {
                const val = (e.target as HTMLInputElement).value;
                if (/^#[0-9A-F]{6}$/i.test(val) && colorInput) {
                    colorInput.value = val;
                }
            });

            addBtn?.addEventListener('click', () => openModal());
            closeBtn?.addEventListener('click', closeModal);
            cancelBtn?.addEventListener('click', closeModal);
            form?.addEventListener('submit', saveCategory);
            deleteBtn?.addEventListener('click', deleteCategory);
        });
    </script>
</Layout>
