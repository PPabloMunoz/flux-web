---
import Layout from "../layouts/Layout.astro";
import RecurrentPaymentModal from "../components/RecurrentPaymentModal.astro";
---

<Layout title="Recurrent Payments">
    <main class="max-w-7xl mx-auto px-6 py-12">
        <!-- Header -->
        <header class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <h1 class="display-lg text-[#f7f8f8]">Recurrent Payments</h1>
                <p class="text-[18px] text-[#8a8f98] mt-2 font-[400]">Manage your automated income and expenses.</p>
            </div>
            <div class="flex gap-3">
                <button class="btn-primary" id="add-recurrent-btn">
                    <i class="fas fa-plus mr-2 text-[10px]"></i> Add Recurrent
                </button>
            </div>
        </header>

        <!-- Payments Table -->
        <section class="glass-card overflow-hidden flex flex-col">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-[rgba(255,255,255,0.05)] bg-[rgba(255,255,255,0.01)]">
                            <th class="px-6 py-4 text-[11px] font-[510] text-[#62666d] uppercase tracking-wider">Payment</th>
                            <th class="px-6 py-4 text-[11px] font-[510] text-[#62666d] uppercase tracking-wider">Frequency</th>
                            <th class="px-6 py-4 text-[11px] font-[510] text-[#62666d] uppercase tracking-wider">Category</th>
                            <th class="px-6 py-4 text-[11px] font-[510] text-[#62666d] uppercase tracking-wider">Next Date</th>
                            <th class="px-6 py-4 text-[11px] font-[510] text-[#62666d] uppercase tracking-wider">Status</th>
                            <th class="px-6 py-4 text-[11px] font-[510] text-[#62666d] uppercase tracking-wider text-right">Amount</th>
                        </tr>
                    </thead>
                    <tbody id="recurrent-rows">
                        <tr>
                            <td colspan="6" class="px-6 py-24 text-center">
                                <div class="inline-block animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-[#5e6ad2] mb-4"></div>
                                <p class="text-[#8a8f98] font-[510]">Loading recurrent payments...</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </main>

    <RecurrentPaymentModal />

    <script>
        import { 
            loadRecurrentPayments, 
            openModal, 
            closeModal, 
            savePayment, 
            handleDelete, 
            updateCategorySelect,
            getModalElements,
            resetModalCache
        } from "../lib/recurrent-payments";

        document.addEventListener('astro:page-load', () => {
            if (window.location.pathname !== '/recurrent-payments' && window.location.pathname !== '/recurrent-payments/') return;

            resetModalCache();
            const elements = getModalElements();

            loadRecurrentPayments();

            elements.addBtn?.addEventListener('click', () => openModal());
            elements.closeModalBtn?.addEventListener('click', closeModal);
            elements.cancelModalBtn?.addEventListener('click', closeModal);
            elements.form?.addEventListener('submit', savePayment);
            elements.deleteBtn?.addEventListener('click', handleDelete);

            elements.accTrigger?.addEventListener('click', (e) => {
                e.stopPropagation();
                document.getElementById('account-dropdown')?.classList.toggle('hidden');
                document.getElementById('category-dropdown')?.classList.add('hidden');
            });

            elements.catTrigger?.addEventListener('click', (e) => {
                e.stopPropagation();
                document.getElementById('category-dropdown')?.classList.toggle('hidden');
                document.getElementById('account-dropdown')?.classList.add('hidden');
            });

            document.addEventListener('click', (e) => {
                const target = e.target as Node;
                const accDropdown = document.getElementById('account-dropdown');
                const catDropdown = document.getElementById('category-dropdown');
                const accTrigger = document.getElementById('account-select-trigger');
                const catTrigger = document.getElementById('category-select-trigger');

                if (!accTrigger?.contains(target) && !accDropdown?.contains(target)) {
                    accDropdown?.classList.add('hidden');
                }
                if (!catTrigger?.contains(target) && !catDropdown?.contains(target)) {
                    catDropdown?.classList.add('hidden');
                }
            });

            document.getElementsByName('type').forEach(radio => {
                radio.addEventListener('change', () => updateCategorySelect());
            });
        });
    </script>
</Layout>
