---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Stats">
    <main class="max-w-7xl mx-auto px-6 py-12">
        <!-- Header -->
        <header class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <h1 class="display-lg text-[#f7f8f8]">Financial Statistics</h1>
                <p class="text-[18px] text-[#8a8f98] mt-2 font-[400]">Analyze your spending habits and income growth over time.</p>
            </div>
            <div class="flex gap-3">
                <div class="flex bg-[rgba(255,255,255,0.03)] border border-[rgba(255,255,255,0.08)] rounded-md p-0.5">
                    <button class="px-3 py-1.5 text-[12px] font-[510] text-[#f7f8f8] bg-[rgba(255,255,255,0.05)] rounded-sm">Monthly</button>
                    <button class="px-3 py-1.5 text-[12px] font-[510] text-[#8a8f98] hover:text-[#d0d6e0] transition-colors">Yearly</button>
                </div>
                <button class="btn-secondary">
                    <i class="fas fa-download mr-2 text-[10px]"></i> Report
                </button>
            </div>
        </header>

        <!-- Main Charts Area -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-12">
            <!-- Spending Overview -->
            <div class="lg:col-span-2 glass-card p-8">
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h2 class="text-[20px] font-[510] tracking-tight text-[#f7f8f8]">Cash Flow</h2>
                        <p class="text-[14px] text-[#8a8f98] mt-1">Income vs Expenses for the last 6 months.</p>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 rounded-full bg-[#5e6ad2]"></div>
                            <span class="text-[12px] text-[#d0d6e0]">Income</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 rounded-full bg-[rgba(255,255,255,0.1)]"></div>
                            <span class="text-[12px] text-[#d0d6e0]">Expenses</span>
                        </div>
                    </div>
                </div>
                
                <div class="h-[300px] flex items-end justify-between gap-4 px-2" id="cashflow-chart">
                    <!-- Dynamic Bars Placeholder -->
                    <div class="flex-1 flex flex-col items-center gap-2">
                        <div class="w-full flex items-end gap-1 h-full">
                            <div class="flex-1 bg-[#5e6ad2] rounded-t-sm" style="height: 60%"></div>
                            <div class="flex-1 bg-[rgba(255,255,255,0.1)] rounded-t-sm" style="height: 40%"></div>
                        </div>
                        <span class="text-[11px] text-[#62666d]">Jan</span>
                    </div>
                    <div class="flex-1 flex flex-col items-center gap-2">
                        <div class="w-full flex items-end gap-1 h-full">
                            <div class="flex-1 bg-[#5e6ad2] rounded-t-sm" style="height: 80%"></div>
                            <div class="flex-1 bg-[rgba(255,255,255,0.1)] rounded-t-sm" style="height: 50%"></div>
                        </div>
                        <span class="text-[11px] text-[#62666d]">Feb</span>
                    </div>
                    <div class="flex-1 flex flex-col items-center gap-2">
                        <div class="w-full flex items-end gap-1 h-full">
                            <div class="flex-1 bg-[#5e6ad2] rounded-t-sm" style="height: 70%"></div>
                            <div class="flex-1 bg-[rgba(255,255,255,0.1)] rounded-t-sm" style="height: 45%"></div>
                        </div>
                        <span class="text-[11px] text-[#62666d]">Mar</span>
                    </div>
                    <div class="flex-1 flex flex-col items-center gap-2">
                        <div class="w-full flex items-end gap-1 h-full">
                            <div class="flex-1 bg-[#5e6ad2] rounded-t-sm" style="height: 90%"></div>
                            <div class="flex-1 bg-[rgba(255,255,255,0.1)] rounded-t-sm" style="height: 60%"></div>
                        </div>
                        <span class="text-[11px] text-[#62666d]">Apr</span>
                    </div>
                    <div class="flex-1 flex flex-col items-center gap-2">
                        <div class="w-full flex items-end gap-1 h-full">
                            <div class="flex-1 bg-[#5e6ad2] rounded-t-sm" style="height: 85%"></div>
                            <div class="flex-1 bg-[rgba(255,255,255,0.1)] rounded-t-sm" style="height: 55%"></div>
                        </div>
                        <span class="text-[11px] text-[#62666d]">May</span>
                    </div>
                    <div class="flex-1 flex flex-col items-center gap-2">
                        <div class="w-full flex items-end gap-1 h-full">
                            <div class="flex-1 bg-[#5e6ad2] rounded-t-sm" style="height: 95%"></div>
                            <div class="flex-1 bg-[rgba(255,255,255,0.1)] rounded-t-sm" style="height: 40%"></div>
                        </div>
                        <span class="text-[11px] text-[#62666d]">Jun</span>
                    </div>
                </div>
            </div>

            <!-- Spending by Category -->
            <div class="glass-card p-8">
                <h2 class="text-[20px] font-[510] tracking-tight text-[#f7f8f8] mb-8">Categories</h2>
                
                <div class="space-y-6">
                    <div>
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-[13px] text-[#d0d6e0]">Housing</span>
                            <span class="text-[13px] font-[510] text-[#f7f8f8]">$1,200.00</span>
                        </div>
                        <div class="w-full h-1.5 bg-[rgba(255,255,255,0.03)] rounded-full overflow-hidden">
                            <div class="h-full bg-[#5e6ad2] rounded-full" style="width: 45%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-[13px] text-[#d0d6e0]">Food & Dining</span>
                            <span class="text-[13px] font-[510] text-[#f7f8f8]">$850.20</span>
                        </div>
                        <div class="w-full h-1.5 bg-[rgba(255,255,255,0.03)] rounded-full overflow-hidden">
                            <div class="h-full bg-[#5e6ad2] rounded-full" style="width: 32%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-[13px] text-[#d0d6e0]">Entertainment</span>
                            <span class="text-[13px] font-[510] text-[#f7f8f8]">$320.50</span>
                        </div>
                        <div class="w-full h-1.5 bg-[rgba(255,255,255,0.03)] rounded-full overflow-hidden">
                            <div class="h-full bg-[#5e6ad2] rounded-full" style="width: 15%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-[13px] text-[#d0d6e0]">Transportation</span>
                            <span class="text-[13px] font-[510] text-[#f7f8f8]">$180.00</span>
                        </div>
                        <div class="w-full h-1.5 bg-[rgba(255,255,255,0.03)] rounded-full overflow-hidden">
                            <div class="h-full bg-[#5e6ad2] rounded-full" style="width: 8%"></div>
                        </div>
                    </div>
                </div>

                <button class="w-full mt-10 py-3 text-[13px] font-[510] text-[#8a8f98] hover:text-[#f7f8f8] border border-[rgba(255,255,255,0.08)] rounded-md transition-all">
                    View Full Breakdown
                </button>
            </div>
        </div>

        <!-- Insights -->
        <section>
            <h2 class="text-[20px] font-[510] tracking-tight text-[#f7f8f8] mb-6">Financial Insights</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="glass-card p-6 border-l-2 border-l-[#10b981]">
                    <div class="flex items-center gap-3 mb-4">
                        <i class="fas fa-lightbulb text-[#10b981]"></i>
                        <h3 class="text-[15px] font-[510] text-[#f7f8f8]">Savings Potential</h3>
                    </div>
                    <p class="text-[13px] text-[#8a8f98] leading-relaxed">
                        You've spent 15% less on entertainment this month. If you continue this trend, you could save $1,400 by end of year.
                    </p>
                </div>
                <div class="glass-card p-6 border-l-2 border-l-[#5e6ad2]">
                    <div class="flex items-center gap-3 mb-4">
                        <i class="fas fa-chart-line text-[#5e6ad2]"></i>
                        <h3 class="text-[15px] font-[510] text-[#f7f8f8]">Income Growth</h3>
                    </div>
                    <p class="text-[13px] text-[#8a8f98] leading-relaxed">
                        Your monthly income has increased by 12% compared to the previous quarter, mostly driven by freelance activities.
                    </p>
                </div>
                <div class="glass-card p-6 border-l-2 border-l-rose-500">
                    <div class="flex items-center gap-3 mb-4">
                        <i class="fas fa-triangle-exclamation text-rose-500"></i>
                        <h3 class="text-[15px] font-[510] text-[#f7f8f8]">Spending Alert</h3>
                    </div>
                    <p class="text-[13px] text-[#8a8f98] leading-relaxed">
                        Subscription costs have increased by $45 this month. Consider reviewing your active streaming services.
                    </p>
                </div>
            </div>
        </section>
    </main>
</Layout>
