---
import "../styles/global.css";
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FinanceFlow | Login</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="text-foreground bg-[#010102] flex items-center justify-center min-h-screen p-6">

    <div class="w-full max-w-[400px] flex flex-col items-center">
        <!-- Brand -->
        <div class="flex flex-col items-center mb-10 text-center">
            <div class="bg-[#5e6ad2] p-2.5 rounded-xl mb-4 shadow-[0_0_20px_rgba(94,106,210,0.3)]">
                <i class="fas fa-wallet text-white text-xl"></i>
            </div>
            <h1 class="text-2xl font-[510] tracking-tight text-[#f7f8f8]">Welcome back</h1>
            <p class="text-[14px] text-[#8a8f98] mt-2">Enter your credentials to access your account</p>
        </div>

        <!-- Form -->
        <div class="glass-card w-full p-10 border-[rgba(255,255,255,0.08)]">
            <form class="space-y-7" id="login-form">
                <div>
                    <label for="email" class="block text-[12px] font-[510] text-[#8a8f98] uppercase tracking-wider mb-2">Email Address</label>
                    <input 
                        type="email" 
                        id="email" 
                        placeholder="name@company.com" 
                        class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-4 py-2.5 text-[14px] text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors"
                        required
                    >
                </div>
                <div>
                    <div class="flex justify-between mb-2">
                        <label for="password" class="block text-[12px] font-[510] text-[#8a8f98] uppercase tracking-wider">Password</label>
                        <a href="#" class="text-[12px] text-[#5e6ad2] hover:text-[#828fff] transition-colors">Forgot password?</a>
                    </div>
                    <input 
                        type="password" 
                        id="password" 
                        placeholder="••••••••" 
                        class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-4 py-2.5 text-[14px] text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors"
                        required
                    >
                </div>

                <button type="submit" class="btn-primary w-full py-2.5 mt-2 justify-center">
                    Sign in
                </button>
            </form>
        </div>

        <p class="text-center text-[14px] text-[#8a8f98] mt-8">
            Don't have an account? 
            <a href="/register" class="text-[#f7f8f8] font-[510] hover:text-[#5e6ad2] transition-colors ml-1">Create one</a>
        </p>
    </div>

    <script>
        const API_URL = import.meta.env.PUBLIC_API_URL;

        // Redirect if already logged in
        async function checkSession() {
            try {
                const response = await fetch(`${API_URL}/me`, {
                    method: 'GET',
                    credentials: 'include'
                });
                if (response.ok) {
                    window.location.href = '/';
                }
            } catch (error) {
                console.error('Session check failed:', error);
            }
        }
        checkSession();

        const loginForm = document.getElementById('login-form') as HTMLFormElement;
        
        if (loginForm) {
            loginForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                const emailInput = document.getElementById('email') as HTMLInputElement;
                const passwordInput = document.getElementById('password') as HTMLInputElement;
                
                if (!emailInput.value || !passwordInput.value) {
                    alert('Please fill in all fields');
                    return;
                }

                try {
                    const response = await fetch(`${API_URL}/auth/login`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            email: emailInput.value,
                            password: passwordInput.value,
                        }),
                        // Include credentials to allow the browser to save the cookie
                        credentials: 'include',
                    });

                    if (response.ok) {
                        window.location.href = '/';
                    } else {
                        const error = await response.json();
                        alert(error.message || 'Login failed. Please check your credentials.');
                    }
                } catch (error) {
                    console.error('Login error:', error);
                    alert('An error occurred. Please try again later.');
                }
            });
        }
    </script>
</body>
</html>
