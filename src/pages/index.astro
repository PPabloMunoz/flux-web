---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Dashboard">
    <main class="max-w-7xl mx-auto px-6 py-12">
        <!-- Header -->
        <header class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <h1 class="display-lg text-[#f7f8f8]">Dashboard Overview</h1>
                <p class="text-[18px] text-[#8a8f98] mt-2 font-[400]">Welcome back. Here's what's happening with your money today.</p>
            </div>
            <div class="flex gap-3">
                <button class="btn-secondary">
                    Export
                </button>
                <button class="btn-primary" id="add-transaction-btn">
                    <i class="fas fa-plus mr-2 text-[10px]"></i> Add Transaction
                </button>
            </div>
        </header>

        <!-- Stats Cards -->
        <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12" id="stats-container">
            <!-- Total Balance -->
            <div class="glass-card p-6">
                <div class="flex items-center justify-between mb-4">
                    <span class="text-[12px] font-[510] text-[#8a8f98] uppercase tracking-wider">Total Balance</span>
                    <div class="w-8 h-8 flex items-center justify-center bg-[rgba(255,255,255,0.03)] rounded-full border border-[rgba(255,255,255,0.08)]">
                        <i class="fas fa-wallet text-[12px] text-[#d0d6e0]"></i>
                    </div>
                </div>
                <div class="text-[32px] font-[510] tracking-tight text-[#f7f8f8]" id="total-balance">$0.00</div>
                <div class="mt-4 flex items-center" id="balance-change-container">
                    <span class="badge-pill" id="balance-change-badge">0%</span>
                    <span class="text-[13px] text-[#62666d]">vs last month</span>
                </div>
            </div>

            <!-- Monthly Income -->
            <div class="glass-card p-6">
                <div class="flex items-center justify-between mb-4">
                    <span class="text-[12px] font-[510] text-[#8a8f98] uppercase tracking-wider">Monthly Income</span>
                    <div class="w-8 h-8 flex items-center justify-center bg-[rgba(255,255,255,0.03)] rounded-full border border-[rgba(255,255,255,0.08)]">
                        <i class="fas fa-arrow-trend-up text-[12px] text-[#10b981]"></i>
                    </div>
                </div>
                <div class="text-[32px] font-[510] tracking-tight text-[#f7f8f8]" id="monthly-income">$0.00</div>
                <div class="mt-4 flex items-center" id="income-change-container">
                    <span class="badge-pill" id="income-change-badge">0%</span>
                    <span class="text-[13px] text-[#62666d]">vs last month</span>
                </div>
            </div>

            <!-- Monthly Expenses -->
            <div class="glass-card p-6">
                <div class="flex items-center justify-between mb-4">
                    <span class="text-[12px] font-[510] text-[#8a8f98] uppercase tracking-wider">Monthly Expenses</span>
                    <div class="w-8 h-8 flex items-center justify-center bg-[rgba(255,255,255,0.03)] rounded-full border border-[rgba(255,255,255,0.08)]">
                        <i class="fas fa-arrow-trend-down text-[12px] text-[#8a8f98]"></i>
                    </div>
                </div>
                <div class="text-[32px] font-[510] tracking-tight text-[#f7f8f8]" id="monthly-expenses">$0.00</div>
                <div class="mt-4 flex items-center" id="expenses-change-container">
                    <span class="badge-pill" id="expenses-change-badge">0%</span>
                    <span class="text-[13px] text-[#62666d]">vs last month</span>
                </div>
            </div>
        </section>

        <!-- Transactions Table -->
        <section class="glass-card overflow-hidden">
            <div class="p-8 border-b border-[rgba(255,255,255,0.08)] flex justify-between items-center">
                <div>
                    <h2 class="text-[20px] font-[510] tracking-tight text-[#f7f8f8]">Recent Transactions</h2>
                    <p class="text-[14px] text-[#8a8f98] mt-1">A summary of your latest financial activity.</p>
                </div>
                <a href="/transactions" class="text-[13px] font-[510] text-[#d0d6e0] hover:text-[#f7f8f8] transition-colors">View All</a>
            </div>
            
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-[rgba(255,255,255,0.05)]">
                            <th class="px-6 py-4 text-[11px] font-[510] text-[#62666d] uppercase tracking-wider">Description</th>
                            <th class="px-6 py-4 text-[11px] font-[510] text-[#62666d] uppercase tracking-wider">Account</th>
                            <th class="px-6 py-4 text-[11px] font-[510] text-[#62666d] uppercase tracking-wider">Category</th>
                            <th class="px-6 py-4 text-[11px] font-[510] text-[#62666d] uppercase tracking-wider">Date</th>
                            <th class="px-6 py-4 text-[11px] font-[510] text-[#62666d] uppercase tracking-wider text-right">Amount</th>
                        </tr>
                    </thead>
                    <tbody id="transaction-rows">
                        <!-- Shimmer Loading State -->
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-[#8a8f98]">
                                <span>Fetching your latest activity...</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </main>

    <!-- Transaction Modal -->
    <div id="transaction-modal" class="fixed inset-0 z-[100] hidden">
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
        <div class="absolute inset-0 flex items-center justify-center p-4">
            <div class="glass-card w-full max-w-md bg-[#0f1011] shadow-2xl animate-in fade-in zoom-in duration-200">
                <div class="p-6 border-b border-[rgba(255,255,255,0.05)] flex items-center justify-between">
                    <h2 class="text-xl font-[510] text-[#f7f8f8]" id="modal-title">Add Transaction</h2>
                    <button id="close-modal" class="text-[#8a8f98] hover:text-[#f7f8f8] transition-colors">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <form id="transaction-form" class="p-6 space-y-4">
                    <div>
                        <label for="title" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Description</label>
                        <input type="text" id="title" name="title" required
                            class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2 text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors"
                            placeholder="e.g. Weekly Groceries" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="amount" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Amount (EUR)</label>
                            <input type="number" id="amount" name="amount" step="0.01" required
                                class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2 text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors"
                                placeholder="0.00" />
                        </div>
                        <div>
                            <label class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Type</label>
                            <div class="flex gap-4 items-center h-[42px]">
                                <label class="flex items-center gap-2 cursor-pointer group">
                                    <input type="radio" name="type" value="expense" class="hidden peer" required>
                                    <div class="w-4 h-4 rounded-full border border-[rgba(255,255,255,0.2)] peer-checked:border-[#5e6ad2] peer-checked:border-[5px] transition-all"></div>
                                    <span class="text-[14px] text-[#8a8f98] group-hover:text-[#f7f8f8] transition-colors">Expense</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer group">
                                    <input type="radio" name="type" value="income" class="hidden peer">
                                    <div class="w-4 h-4 rounded-full border border-[rgba(255,255,255,0.2)] peer-checked:border-[#10b981] peer-checked:border-[5px] transition-all"></div>
                                    <span class="text-[14px] text-[#8a8f98] group-hover:text-[#f7f8f8] transition-colors">Income</span>
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="relative">
                        <label for="account_id" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Account</label>
                        <input type="hidden" id="account_id" name="account_id" required />
                        <button type="button" id="account-select-trigger" 
                            class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2.5 text-[#f7f8f8] flex items-center justify-between focus:outline-none focus:border-[#5e6ad2] transition-colors group">
                            <span id="selected-account-label" class="text-[#8a8f98]">Select Account</span>
                            <i class="fas fa-chevron-down text-[10px] text-[#62666d] group-hover:text-[#8a8f98] transition-colors"></i>
                        </button>
                        
                        <div id="account-dropdown" class="absolute left-0 right-0 mt-2 bg-[#161718] border border-[rgba(255,255,255,0.08)] rounded-lg shadow-2xl hidden z-50 max-h-60 overflow-y-auto custom-scrollbar">
                            <div id="account-options" class="p-1.5 space-y-1">
                                <!-- Options will be injected here -->
                            </div>
                        </div>
                    </div>
                    <div class="relative">
                        <label for="category_id" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Category</label>
                        <input type="hidden" id="category_id" name="category_id" required />
                        <button type="button" id="category-select-trigger" disabled
                            class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2.5 text-[#f7f8f8] flex items-center justify-between focus:outline-none focus:border-[#5e6ad2] transition-colors group disabled:opacity-50 disabled:cursor-not-allowed">
                            <span id="selected-category-label" class="text-[#8a8f98]">Select a type first</span>
                            <i class="fas fa-chevron-down text-[10px] text-[#62666d] group-hover:text-[#8a8f98] transition-colors"></i>
                        </button>
                        
                        <div id="category-dropdown" class="absolute left-0 right-0 mt-2 bg-[#161718] border border-[rgba(255,255,255,0.08)] rounded-lg shadow-2xl hidden z-50 max-h-60 overflow-y-auto custom-scrollbar">
                            <div id="category-options" class="p-1.5 space-y-1">
                                <!-- Options will be injected here -->
                            </div>
                        </div>
                    </div>
                    <div>
                        <label for="date" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Date</label>
                        <input type="date" id="date" name="date" required
                            class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2 text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors" />
                    </div>
                    <div>
                        <label for="notes" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Notes</label>
                        <textarea id="notes" name="notes" rows="3"
                            class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2 text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors resize-none"
                            placeholder="Add additional details..."></textarea>
                    </div>
                    <div class="pt-4 flex gap-3 justify-end">
                        <button type="button" id="cancel-modal" class="btn-secondary">Cancel</button>
                        <button type="submit" class="btn-primary">Save Transaction</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        import type { DashboardData, Transaction } from "../types/dashboard";
        import type { Account } from "../types/account";
        import type { Category } from "../types/category";

        /**
         * Configuration
         */
        const API_URL = import.meta.env.PUBLIC_API_URL; 

        // In-memory cache
        let dashboardCache: DashboardData | null = null;
        let accounts: Account[] = [];
        let categories: Category[] = [];

        function getModalElements() {
            return {
                modal: document.getElementById('transaction-modal'),
                form: document.getElementById('transaction-form') as HTMLFormElement,
                addBtn: document.getElementById('add-transaction-btn'),
                closeModalBtn: document.getElementById('close-modal'),
                cancelModalBtn: document.getElementById('cancel-modal'),
                accTrigger: document.getElementById('account-select-trigger'),
                catTrigger: document.getElementById('category-select-trigger'),
                dateInput: document.getElementById('date') as HTMLInputElement,
                accLabel: document.getElementById('selected-account-label'),
                accInput: document.getElementById('account_id') as HTMLInputElement,
                catLabel: document.getElementById('selected-category-label'),
                catInput: document.getElementById('category_id') as HTMLInputElement
            };
        }

        async function fetchInitialData() {
            if(accounts.length != 0 && categories.length != 0) return

            try {
                const [accRes, catRes] = await Promise.all([
                    fetch(`${API_URL}/account`, { credentials: 'include' }),
                    fetch(`${API_URL}/category`, { credentials: 'include' })
                ]);
                
                if (accRes.status === 401 || catRes.status === 401) {
                    window.location.href = '/login';
                    return;
                }

                accounts = await accRes.json();
                categories = await catRes.json();

                populateSelects();
            } catch (error) {
                console.error('Error fetching initial data:', error);
            }
        }

        function populateSelects() {
            const accountOptions = document.getElementById('account-options');
            const selectedLabel = document.getElementById('selected-account-label');
            const accountIdInput = document.getElementById('account_id') as HTMLInputElement;
            const accountDropdown = document.getElementById('account-dropdown');

            if (!accountOptions || !selectedLabel || !accountIdInput || !accountDropdown) return;

            const currencyFormatter = new Intl.NumberFormat('es-ES', { 
                style: 'currency', 
                currency: 'EUR' 
            });

            accountOptions.innerHTML = '';
            accounts.forEach(acc => {
                const option = document.createElement('button');
                option.type = 'button';
                option.className = 'w-full text-left px-3 py-2.5 rounded-md hover:bg-[rgba(255,255,255,0.05)] transition-colors flex items-center justify-between group';
                
                option.innerHTML = `
                    <div class="flex flex-col">
                        <span class="text-[14px] font-[510] text-[#f7f8f8]">${acc.name}</span>
                        <span class="text-[10px] text-[#62666d]">ID: ${acc.id}</span>
                    </div>
                    <span class="text-[13px] font-[510] text-[#8a8f98] group-hover:text-[#f7f8f8]">${currencyFormatter.format(acc.balance / 100)}</span>
                `;

                option.onclick = () => {
                    accountIdInput.value = acc.id.toString();
                    selectedLabel.textContent = acc.name;
                    selectedLabel.classList.remove('text-[#8a8f98]');
                    selectedLabel.classList.add('text-[#f7f8f8]');
                    accountDropdown.classList.add('hidden');
                };

                accountOptions.appendChild(option);
            });

            // Initial category setup
            updateCategorySelect();
        }

        function updateCategorySelect() {
            const categoryOptions = document.getElementById('category-options');
            const selectedLabel = document.getElementById('selected-category-label');
            const categoryIdInput = document.getElementById('category_id') as HTMLInputElement;
            const categoryTrigger = document.getElementById('category-select-trigger') as HTMLButtonElement;
            const categoryDropdown = document.getElementById('category-dropdown');

            const typeRadios = document.getElementsByName('type') as NodeListOf<HTMLInputElement>;
            let selectedType = "";
            
            typeRadios.forEach(r => {
                if (r.checked) selectedType = r.value;
            });

            if (!categoryOptions || !selectedLabel || !categoryIdInput || !categoryTrigger || !categoryDropdown) return;

            // Reset current selection when type changes
            categoryIdInput.value = "";
            selectedLabel.classList.remove('text-[#f7f8f8]');
            selectedLabel.classList.add('text-[#8a8f98]');

            if (!selectedType) {
                selectedLabel.textContent = 'Select a type first';
                categoryTrigger.disabled = true;
                categoryOptions.innerHTML = '';
                return;
            }

            categoryTrigger.disabled = false;
            selectedLabel.textContent = 'Select Category';
            categoryOptions.innerHTML = '';
            
            const filteredCategories = categories.filter(cat => cat.type === selectedType);
            
            filteredCategories.forEach(cat => {
                const option = document.createElement('button');
                option.type = 'button';
                option.className = 'w-full text-left px-3 py-2.5 rounded-md hover:bg-[rgba(255,255,255,0.05)] transition-colors flex items-center gap-3 group';
                
                option.innerHTML = `
                    <div class="w-2 h-2 rounded-full" style="background-color: ${cat.color || '#8a8f98'}"></div>
                    <span class="text-[14px] font-[510] text-[#f7f8f8]">${cat.name}</span>
                `;

                option.onclick = () => {
                    categoryIdInput.value = cat.id.toString();
                    selectedLabel.textContent = cat.name;
                    selectedLabel.classList.remove('text-[#8a8f98]');
                    selectedLabel.classList.add('text-[#f7f8f8]');
                    categoryDropdown.classList.add('hidden');
                };

                categoryOptions.appendChild(option);
            });
        }

        function openModal() {
            const { modal, form, dateInput, accLabel, accInput, catLabel, catInput } = getModalElements();
            if (!modal || !form) return;

            form.reset();
            if (dateInput) dateInput.value = new Date().toISOString().split('T')[0];
            
            // Reset custom account select
            if (accLabel && accInput) {
                accLabel.textContent = 'Select Account';
                accLabel.classList.remove('text-[#f7f8f8]');
                accLabel.classList.add('text-[#8a8f98]');
                accInput.value = '';
            }

            // Reset custom category select
            if (catLabel && catInput) {
                catLabel.textContent = 'Select a type first';
                catLabel.classList.remove('text-[#f7f8f8]');
                catLabel.classList.add('text-[#8a8f98]');
                catInput.value = '';
            }

            updateCategorySelect();
            
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            const { modal } = getModalElements();
            if (modal) {
                modal.classList.add('hidden');
                document.getElementById('account-dropdown')?.classList.add('hidden');
                document.getElementById('category-dropdown')?.classList.add('hidden');
            }
            document.body.style.overflow = '';
        }

        async function saveTransaction(e: SubmitEvent) {
            e.preventDefault();
            const { form, accInput, catInput } = getModalElements();
            if (!form) return;

            const formData = new FormData(form);
            const accountId = accInput?.value;
            const categoryId = catInput?.value;
            
            if (!accountId) {
                alert('Please select an account');
                return;
            }
            if (!categoryId) {
                alert('Please select a category');
                return;
            }

            const data: any = {
                title: formData.get('title'),
                amount: Math.round(parseFloat(formData.get('amount') as string) * 100),
                type: formData.get('type'),
                date: (formData.get('date') as string),
                account_id: parseInt(accountId),
                category_id: parseInt(categoryId),
                notes: formData.get('notes')
            };

            try {
                const response = await fetch(`${API_URL}/transaction`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data),
                    credentials: 'include'
                });

                if (!response.ok) throw new Error('Failed to save transaction');
                
                dashboardCache = null;
                await fetchDashboardData();
                closeModal();
            } catch (error) {
                console.error('Save error:', error);
                alert('Failed to save transaction');
            }
        }

        /**
         * Render Data to the DOM
         */
        function renderDashboard(data: DashboardData) {
            // Update Stats
            const balanceEl = document.getElementById('total-balance');
            const incomeEl = document.getElementById('monthly-income');
            const expenseEl = document.getElementById('monthly-expenses');

            const currencyFormatter = new Intl.NumberFormat('es-ES', { 
                style: 'currency', 
                currency: 'EUR' 
            });

            const format = (val: number) => currencyFormatter.format(val / 100);

            if(balanceEl) balanceEl.textContent = format(data.total_balance);
            if(incomeEl) incomeEl.textContent = format(data.monthly_income);
            if(expenseEl) expenseEl.textContent = format(data.monthly_expenses);

            // Update Percentages
            const updatePercentage = (id: string, value: number, invertColors = false) => {
                const el = document.getElementById(id);
                if (!el) return;
                
                const val = value || 0;
                const isPositive = val > 0;
                const isZero = val === 0;
                
                el.textContent = `${isPositive ? '+' : ''}${val.toFixed(1)}%`;
                
                // Determine colors
                let colorClass = 'bg-[rgba(255,255,255,0.05)] text-[#8a8f98]'; // neutral/zero
                if (!isZero) {
                    const positiveIsGood = !invertColors;
                    if (isPositive === positiveIsGood) {
                        colorClass = 'bg-[rgba(16,185,129,0.1)] text-[#10b981]'; // Green
                    } else {
                        colorClass = 'bg-[rgba(248,113,113,0.1)] text-[#f87171]'; // Red
                    }
                }
                
                el.className = `badge-pill border-none mr-2 ${colorClass}`;
            };

            updatePercentage('balance-change-badge', data.total_balance_change_pct);
            updatePercentage('income-change-badge', data.monthly_income_change_pct);
            updatePercentage('expenses-change-badge', data.monthly_expenses_change_pct, true);

            // Update Transactions
            const rowsContainer = document.getElementById('transaction-rows');
            if (!rowsContainer) return;
            
            rowsContainer.innerHTML = '';

            if (!data.last_transactions || data.last_transactions.length === 0) {
                rowsContainer.innerHTML = '<tr><td colspan="5" class="px-6 py-8 text-center text-[#8a8f98]">No transactions found.</td></tr>';
                return;
            }

            data.last_transactions.forEach((tx: Transaction) => {
                const isIncome = tx.type === 'income';
                const row = document.createElement('tr');
                row.className = 'hover:bg-[rgba(255,255,255,0.02)] transition-colors group border-b border-[rgba(255,255,255,0.03)]';
                
                // Format date: fallback to "Recent" if empty
                const displayDate = tx.date ? new Date(tx.date).toLocaleDateString('es-ES') : 'Reciente';
                
                row.innerHTML = `
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full flex items-center justify-center ${isIncome ? 'bg-[rgba(16,185,129,0.1)] text-[#10b981]' : 'bg-[rgba(248,113,113,0.1)] text-[#f87171]'}">
                                <i class="fas ${isIncome ? 'fa-plus' : 'fa-receipt'} text-[10px]"></i>
                            </div>
                            <span class="text-[14px] font-[510] text-[#f7f8f8]">${tx.title || 'Transacción sin título'}</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-[13px] text-[#8a8f98]">
                        ${tx.account_name || 'Unknown'}
                    </td>
                    <td class="px-6 py-4">
                        <span class="badge-pill bg-[rgba(255,255,255,0.03)] flex items-center w-fit gap-1.5">
                            <div class="w-1.5 h-1.5 rounded-full" style="background-color: ${tx.category_color || '#8a8f98'}"></div>
                            ${tx.transfer_id 
                                ? `<i class="fas fa-right-left text-[10px] opacity-50"></i> TRANSFER` 
                                : (tx.category_name || '-')}
                        </span>
                    </td>
                    <td class="px-6 py-4 text-[13px] text-[#62666d]">
                        ${displayDate}
                    </td>
                    <td class="px-6 py-4 text-right">
                        <span class="text-[14px] font-[510] ${isIncome ? 'text-[#10b981]' : 'text-[#f87171]'}">
                            ${isIncome ? '+' : '-'}${format(tx.amount)}
                        </span>
                    </td>
                `;
                rowsContainer.appendChild(row);
            });
        }

        /**
         * Fetch Data from your Golang API
         */
        async function fetchDashboardData() {
            await fetchInitialData();
            if (dashboardCache) {
                renderDashboard(dashboardCache);
                return; // STOP HERE if we have data
            }

            try {
                const response = await fetch(`${API_URL}/dashboard`, {
                    credentials: 'include'
                });

                if (response.status === 401) {
                    window.location.href = '/login';
                    return;
                }

                if (!response.ok) throw new Error('Failed to fetch dashboard data');

                const data = await response.json();
                dashboardCache = data;
                renderDashboard(data);
            } catch (error) {
                console.error('Error fetching data:', error);
                const rowsContainer = document.getElementById('transaction-rows');
                if (rowsContainer && !dashboardCache) {
                    rowsContainer.innerHTML = `
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-rose-500">
                                <i class="fas fa-exclamation-triangle text-2xl mb-2"></i>
                                <p>Failed to connect to backend API. Please check if your Go server is running.</p>
                            </td>
                        </tr>
                    `;
                }
            }
        }

        // Initialize on page load
        document.addEventListener('astro:page-load', () => {
            const { addBtn, closeModalBtn, cancelModalBtn, form, accTrigger, catTrigger } = getModalElements();

            fetchDashboardData();

            addBtn?.addEventListener('click', () => openModal());
            closeModalBtn?.addEventListener('click', closeModal);
            cancelModalBtn?.addEventListener('click', closeModal);
            form?.addEventListener('submit', saveTransaction);
            
            accTrigger?.addEventListener('click', (e) => {
                e.stopPropagation();
                document.getElementById('account-dropdown')?.classList.toggle('hidden');
                document.getElementById('category-dropdown')?.classList.add('hidden');
            });

            catTrigger?.addEventListener('click', (e) => {
                e.stopPropagation();
                document.getElementById('category-dropdown')?.classList.toggle('hidden');
                document.getElementById('account-dropdown')?.classList.add('hidden');
            });

            document.addEventListener('click', (e) => {
                const trigger1 = document.getElementById('account-select-trigger');
                const trigger2 = document.getElementById('category-select-trigger');
                const dropdown1 = document.getElementById('account-dropdown');
                const dropdown2 = document.getElementById('category-dropdown');

                if (!trigger1?.contains(e.target as Node) && !dropdown1?.contains(e.target as Node)) {
                    dropdown1?.classList.add('hidden');
                }
                if (!trigger2?.contains(e.target as Node) && !dropdown2?.contains(e.target as Node)) {
                    dropdown2?.classList.add('hidden');
                }
            });

            // Add event listeners for type radio buttons
            document.getElementsByName('type').forEach(radio => {
                radio.addEventListener('change', updateCategorySelect);
            });
        });
    </script>
</Layout>
