---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Transactions">
    <main class="max-w-7xl mx-auto px-6 py-12">
        <!-- Header -->
        <header class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <h1 class="display-lg text-[#f7f8f8]">Transactions</h1>
                <p class="text-[18px] text-[#8a8f98] mt-2 font-[400]">Review and manage your financial activity.</p>
            </div>
            <div class="flex gap-3">
                <button class="btn-primary" id="add-transaction-btn">
                    <i class="fas fa-plus mr-2 text-[10px]"></i> Add Transaction
                </button>
            </div>
        </header>

        <!-- Transactions Table -->
        <section class="glass-card overflow-hidden flex flex-col">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-[rgba(255,255,255,0.05)]">
                            <th class="px-6 py-4 text-[11px] font-[510] text-[#62666d] uppercase tracking-wider">Description</th>
                            <th class="px-6 py-4 text-[11px] font-[510] text-[#62666d] uppercase tracking-wider">Account</th>
                            <th class="px-6 py-4 text-[11px] font-[510] text-[#62666d] uppercase tracking-wider">Category</th>
                            <th class="px-6 py-4 text-[11px] font-[510] text-[#62666d] uppercase tracking-wider">Date</th>
                            <th class="px-6 py-4 text-[11px] font-[510] text-[#62666d] uppercase tracking-wider text-right">Amount</th>
                        </tr>
                    </thead>
                    <tbody id="transaction-rows">
                        <!-- Loading State -->
                        <tr>
                            <td colspan="5" class="px-6 py-24 text-center">
                                <div class="inline-block animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-[#5e6ad2] mb-4"></div>
                                <p class="text-[#8a8f98] font-[510]">Loading transactions...</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="px-6 py-4 border-t border-[rgba(255,255,255,0.05)] flex items-center justify-between bg-[rgba(255,255,255,0.01)]">
                <div class="text-[13px] text-[#62666d]">
                    Showing <span id="page-range" class="text-[#8a8f98] font-[510]">-</span> of <span id="total-count" class="text-[#8a8f98] font-[510]">-</span> transactions
                </div>
                <div class="flex items-center gap-2">
                    <button id="prev-page" class="px-3 py-1.5 rounded-md border border-[rgba(255,255,255,0.08)] text-[13px] font-[510] text-[#8a8f98] hover:text-[#f7f8f8] hover:bg-[rgba(255,255,255,0.02)] transition-colors disabled:opacity-30 disabled:cursor-not-allowed">
                        Previous
                    </button>
                    <button id="next-page" class="px-3 py-1.5 rounded-md border border-[rgba(255,255,255,0.08)] text-[13px] font-[510] text-[#8a8f98] hover:text-[#f7f8f8] hover:bg-[rgba(255,255,255,0.02)] transition-colors disabled:opacity-30 disabled:cursor-not-allowed">
                        Next
                    </button>
                </div>
            </div>
        </section>
    </main>

    <!-- Transaction Modal -->
    <div id="transaction-modal" class="fixed inset-0 z-[100] hidden">
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
        <div class="absolute inset-0 flex items-center justify-center p-4">
            <div class="glass-card w-full max-w-md bg-[#0f1011] shadow-2xl animate-in fade-in zoom-in duration-200">
                <div class="p-6 border-b border-[rgba(255,255,255,0.05)] flex items-center justify-between">
                    <h2 class="text-xl font-[510] text-[#f7f8f8]" id="modal-title">Add Transaction</h2>
                    <button id="close-modal" class="text-[#8a8f98] hover:text-[#f7f8f8] transition-colors">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <form id="transaction-form" class="p-6 space-y-4">
                    <input type="hidden" id="transaction-id" name="id" />
                    <div>
                        <label for="title" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Description</label>
                        <input type="text" id="title" name="title" required
                            class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2 text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors"
                            placeholder="e.g. Weekly Groceries" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="amount" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Amount (EUR)</label>
                            <input type="number" id="amount" name="amount" step="0.01" required
                                class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2 text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors"
                                placeholder="0.00" />
                        </div>
                        <div>
                            <label for="type" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Type</label>
                            <select id="type" name="type" required
                                class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2 text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors">
                                <option value="expense">Expense</option>
                                <option value="income">Income</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label for="account_id" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Account</label>
                        <select id="account_id" name="account_id" required
                            class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2 text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors">
                            <option value="">Select Account</option>
                        </select>
                    </div>
                    <div>
                        <label for="category_id" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Category</label>
                        <select id="category_id" name="category_id"
                            class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2 text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors">
                            <option value="">Select Category</option>
                        </select>
                    </div>
                    <div>
                        <label for="date" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Date</label>
                        <input type="date" id="date" name="date" required
                            class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2 text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors" />
                    </div>
                    <div class="pt-4 flex gap-3">
                        <button type="button" id="delete-transaction-btn" class="hidden px-4 py-2 text-rose-500 hover:bg-rose-500/10 rounded-md text-sm font-[510] transition-colors mr-auto">
                            Delete
                        </button>
                        <button type="button" id="cancel-modal" class="btn-secondary">Cancel</button>
                        <button type="submit" class="btn-primary">Save Transaction</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        import type { Transaction } from "../types/dashboard";
        import type { Account } from "../types/account";
        import type { Category } from "../types/category";

        const API_URL = import.meta.env.PUBLIC_API_URL; 
        const PAGE_SIZE = 20;

        let currentPage = 0;
        let totalTransactions = 0;
        let accounts: Account[] = [];
        let categories: Category[] = [];

        const modal = document.getElementById('transaction-modal');
        const form = document.getElementById('transaction-form') as HTMLFormElement;
        const modalTitle = document.getElementById('modal-title');
        const deleteBtn = document.getElementById('delete-transaction-btn');

        async function fetchInitialData() {
            if(accounts.length != 0 && categories.length != 0) return

            try {
                const [accRes, catRes] = await Promise.all([
                    fetch(`${API_URL}/account`, { credentials: 'include' }),
                    fetch(`${API_URL}/category`, { credentials: 'include' })
                ]);
                
                if (accRes.status === 401 || catRes.status === 401) {
                    window.location.href = '/login';
                    return;
                }

                accounts = await accRes.json();
                categories = await catRes.json();

                populateSelects();
            } catch (error) {
                console.error('Error fetching initial data:', error);
            }
        }

        function populateSelects() {
            const accSelect = document.getElementById('account_id') as HTMLSelectElement;
            const catSelect = document.getElementById('category_id') as HTMLSelectElement;

            if (!accSelect || !catSelect) return;

            accSelect.innerHTML = '<option value="">Select Account</option>';
            accounts.forEach(acc => {
                const opt = document.createElement('option');
                opt.value = acc.id.toString();
                opt.textContent = `${acc.name} (ID: ${acc.id})`;
                accSelect.appendChild(opt);
            });

            catSelect.innerHTML = '<option value="">Select Category</option>';
            categories.forEach(cat => {
                const opt = document.createElement('option');
                opt.value = cat.id.toString();
                opt.textContent = cat.name;
                catSelect.appendChild(opt);
            });
        }

        function openModal(tx: Transaction | null = null) {
            if (!modal || !modalTitle || !deleteBtn) return;

            if (tx) {
                modalTitle.textContent = 'Edit Transaction';
                (document.getElementById('transaction-id') as HTMLInputElement).value = tx.id.toString();
                (document.getElementById('title') as HTMLInputElement).value = tx.title;
                (document.getElementById('amount') as HTMLInputElement).value = (tx.amount / 100).toString();
                (document.getElementById('type') as HTMLSelectElement).value = tx.type;
                (document.getElementById('account_id') as HTMLSelectElement).value = tx.account_id.toString();
                (document.getElementById('category_id') as HTMLSelectElement).value = tx.category_id ? tx.category_id.toString() : '';
                (document.getElementById('date') as HTMLInputElement).value = tx.date.split('T')[0];
                deleteBtn.classList.remove('hidden');
            } else {
                modalTitle.textContent = 'Add Transaction';
                form.reset();
                (document.getElementById('transaction-id') as HTMLInputElement).value = '';
                (document.getElementById('date') as HTMLInputElement).value = new Date().toISOString().split('T')[0];
                deleteBtn.classList.add('hidden');
            }
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            if (modal) {
                modal.classList.add('hidden');
            }
            document.body.style.overflow = '';
        }

        async function saveTransaction(e: SubmitEvent) {
            e.preventDefault();
            const formData = new FormData(form);
            const id = formData.get('id');
            const data: any = {
                title: formData.get('title'),
                amount: Math.round(parseFloat(formData.get('amount') as string) * 100),
                type: formData.get('type'),
                date: (formData.get('date') as string),
                account_id: parseInt(formData.get('account_id') as string)
            };

            const categoryId = formData.get('category_id');
            data.category_id = categoryId ? parseInt(categoryId as string) : null;

            const url = id ? `${API_URL}/transaction/${id}` : `${API_URL}/transaction`;
            const method = id ? 'PUT' : 'POST';

            try {
                const response = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data),
                    credentials: 'include'
                });

                if (!response.ok) throw new Error('Failed to save transaction');
                
                await init();
                closeModal();
            } catch (error) {
                console.error('Save error:', error);
                alert('Failed to save transaction');
            }
        }

        async function deleteTransaction() {
            const id = (document.getElementById('transaction-id') as HTMLInputElement).value;
            if (!id || !confirm('Are you sure you want to delete this transaction?')) return;

            try {
                const response = await fetch(`${API_URL}/transaction/${id}`, {
                    method: 'DELETE',
                    credentials: 'include'
                });

                if (!response.ok) throw new Error('Failed to delete transaction');
                
                await init();
                closeModal();
            } catch (error) {
                console.error('Delete error:', error);
                alert('Failed to delete transaction');
            }
        }

        function renderTransactions(transactions: Transaction[]) {
            const rowsContainer = document.getElementById('transaction-rows');
            const pageRange = document.getElementById('page-range');
            const totalCount = document.getElementById('total-count');
            const prevBtn = document.getElementById('prev-page') as HTMLButtonElement;
            const nextBtn = document.getElementById('next-page') as HTMLButtonElement;

            if (!rowsContainer) return;
            
            rowsContainer.innerHTML = '';

            if (pageRange) {
                const start = totalTransactions === 0 ? 0 : (currentPage * PAGE_SIZE) + 1;
                const end = Math.min((currentPage + 1) * PAGE_SIZE, totalTransactions);
                pageRange.textContent = `${start}-${end}`;
            }
            if (totalCount) totalCount.textContent = totalTransactions.toString();
            
            if (prevBtn) prevBtn.disabled = currentPage === 0;
            if (nextBtn) nextBtn.disabled = (currentPage + 1) * PAGE_SIZE >= totalTransactions;

            const currencyFormatter = new Intl.NumberFormat('es-ES', { 
                style: 'currency', 
                currency: 'EUR' 
            });

            if (transactions.length === 0) {
                rowsContainer.innerHTML = '<tr><td colspan="5" class="px-6 py-12 text-center text-[#8a8f98]">No transactions found.</td></tr>';
                return;
            }

            transactions.forEach((tx: Transaction) => {
                const isIncome = tx.type === 'income';
                const row = document.createElement('tr');
                row.className = 'hover:bg-[rgba(255,255,255,0.02)] transition-colors group cursor-pointer border-b border-[rgba(255,255,255,0.03)]';
                row.onclick = () => openModal(tx);
                
                const displayDate = new Date(tx.date).toLocaleDateString('es-ES');
                const accountName = tx.account_name || 'Unknown';
                const categoryName = categories.find(c => c.id === tx.category_id)?.name || 'Uncategorized';
                const categoryColor = categories.find(c => c.id === tx.category_id)?.color || '#8a8f98';

                row.innerHTML = `
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full flex items-center justify-center ${isIncome ? 'bg-[rgba(16,185,129,0.1)] text-[#10b981]' : 'bg-[rgba(248,113,113,0.1)] text-[#f87171]'}">
                                <i class="fas ${isIncome ? 'fa-plus' : 'fa-receipt'} text-[10px]"></i>
                            </div>
                            <span class="text-[14px] font-[510] text-[#f7f8f8]">${tx.title || 'Untitled'}</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-[13px] text-[#8a8f98]">
                        ${accountName}
                    </td>
                    <td class="px-6 py-4 text-[13px] text-[#8a8f98]">
                        ${accountName}
                    </td>
                    <td class="px-6 py-4">
                        <span class="badge-pill bg-[rgba(255,255,255,0.03)] flex items-center w-fit gap-1.5">
                            <div class="w-1.5 h-1.5 rounded-full" style="background-color: ${tx.transfer_id ? '#8a8f98' : categoryColor}"></div>
                            ${tx.transfer_id 
                                ? `<i class="fas fa-right-left text-[10px] opacity-50"></i> TRANSFER` 
                                : categoryName}
                        </span>
                    </td>
                    <td class="px-6 py-4 text-[13px] text-[#62666d]">
                        ${displayDate}
                    </td>
                    <td class="px-6 py-4 text-right">
                        <span class="text-[14px] font-[510] ${isIncome ? 'text-[#10b981]' : 'text-[#f87171]'}">
                            ${isIncome ? '+' : '-'}${currencyFormatter.format(tx.amount / 100)}
                        </span>
                    </td>
                `;
                rowsContainer.appendChild(row);
            });
        }

        async function init() {
            await fetchInitialData();

            try {
                const response = await fetch(`${API_URL}/transaction?limit=${PAGE_SIZE}&offset=${currentPage * PAGE_SIZE}`, {
                    credentials: 'include'
                });

                if (response.status === 401) {
                    window.location.href = '/login';
                    return;
                }

                if (!response.ok) throw new Error('Failed to fetch transactions');

                const data = await response.json();
                // Assuming the API returns { transactions: Transaction[], total: number } 
                // or just Transaction[] if it doesn't support total yet (we'll handle both)
                let transactions: Transaction[] = [];
                if (Array.isArray(data)) {
                    transactions = data;
                    // If it's just an array, we can't know the real total, but we can guess
                    totalTransactions = currentPage * PAGE_SIZE + transactions.length + (transactions.length === PAGE_SIZE ? 1 : 0);
                } else {
                    transactions = data.transactions;
                    totalTransactions = data.total;
                }

                renderTransactions(transactions);
            } catch (error) {
                console.error('Fetch error:', error);
                const rowsContainer = document.getElementById('transaction-rows');
                if (rowsContainer) {
                    rowsContainer.innerHTML = `
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-rose-500">
                                <p>Error loading transactions. Please try again later.</p>
                            </td>
                        </tr>
                    `;
                }
            }
        }

        function handlePrevPage() {
            if (currentPage > 0) {
                currentPage--;
                init();
            }
        }

        function handleNextPage() {
            if ((currentPage + 1) * PAGE_SIZE < totalTransactions) {
                currentPage++;
                init();
            }
        }

        document.addEventListener('astro:page-load', () => {
            init();

            document.getElementById('add-transaction-btn')?.addEventListener('click', () => openModal());
            document.getElementById('close-modal')?.addEventListener('click', closeModal);
            document.getElementById('cancel-modal')?.addEventListener('click', closeModal);
            document.getElementById('transaction-form')?.addEventListener('submit', saveTransaction);
            document.getElementById('delete-transaction-btn')?.addEventListener('click', deleteTransaction);
            document.getElementById('prev-page')?.addEventListener('click', handlePrevPage);
            document.getElementById('next-page')?.addEventListener('click', handleNextPage);
        });
    </script>
</Layout>
