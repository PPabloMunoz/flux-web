---
import "../styles/global.css";
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FinanceFlow | Register</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="text-foreground bg-[#010102] flex items-center justify-center min-h-screen p-6">

    <div class="w-full max-w-[440px] flex flex-col items-center">
        <!-- Brand -->
        <div class="flex flex-col items-center mb-10 text-center">
            <div class="bg-[#5e6ad2] p-2.5 rounded-xl mb-4 shadow-[0_0_20px_rgba(94,106,210,0.3)]">
                <i class="fas fa-wallet text-white text-xl"></i>
            </div>
            <h1 class="text-2xl font-[510] tracking-tight text-[#f7f8f8]">Create your account</h1>
            <p class="text-[14px] text-[#8a8f98] mt-2">Start managing your finances with precision</p>
        </div>

        <!-- Form -->
        <div class="glass-card w-full p-10 border-[rgba(255,255,255,0.08)]">
            <form class="space-y-7" id="register-form">
                <div>
                    <label for="email" class="block text-[12px] font-[510] text-[#8a8f98] uppercase tracking-wider mb-2">Email Address</label>
                    <input 
                        type="email" 
                        id="email" 
                        placeholder="name@company.com" 
                        class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-4 py-2.5 text-[14px] text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors"
                        required
                    >
                </div>

                <div>
                    <label for="password" class="block text-[12px] font-[510] text-[#8a8f98] uppercase tracking-wider mb-2">Password</label>
                    <input 
                        type="password" 
                        id="password" 
                        placeholder="••••••••" 
                        class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-4 py-2.5 text-[14px] text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors"
                        required
                    >
                </div>

                <div>
                    <label for="confirm-password" class="block text-[12px] font-[510] text-[#8a8f98] uppercase tracking-wider mb-2">Confirm Password</label>
                    <input 
                        type="password" 
                        id="confirm-password" 
                        placeholder="••••••••" 
                        class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-4 py-2.5 text-[14px] text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors"
                        required
                    >
                </div>

                <div class="flex items-start gap-3 pt-2">
                    <input 
                        type="checkbox" 
                        id="terms" 
                        class="mt-1 accent-[#5e6ad2]"
                        required
                    >
                    <label for="terms" class="text-[12px] text-[#8a8f98] leading-relaxed">
                        I agree to the <a href="#" class="text-[#d0d6e0] hover:text-[#5e6ad2]">Terms of Service</a> and <a href="#" class="text-[#d0d6e0] hover:text-[#5e6ad2]">Privacy Policy</a>.
                    </label>
                </div>

                <button type="submit" class="btn-primary w-full py-2.5 mt-2 justify-center">
                    Create Account
                </button>
            </form>
        </div>

        <p class="text-center text-[14px] text-[#8a8f98] mt-8">
            Already have an account? 
            <a href="/login" class="text-[#f7f8f8] font-[510] hover:text-[#5e6ad2] transition-colors ml-1">Sign in</a>
        </p>
    </div>

    <script>
        const API_URL = import.meta.env.PUBLIC_API_URL;

        // Redirect if already logged in
        async function checkSession() {
            try {
                const response = await fetch(`${API_URL}/me`, {
                    method: 'GET',
                    credentials: 'include'
                });
                if (response.ok) {
                    window.location.href = '/';
                }
            } catch (error) {
                console.error('Session check failed:', error);
            }
        }
        checkSession();

        const registerForm = document.getElementById('register-form') as HTMLFormElement;

        if (registerForm) {
            registerForm.addEventListener('submit', async (e) => {
                e.preventDefault();

                const emailInput = document.getElementById('email') as HTMLInputElement;
                const passwordInput = document.getElementById('password') as HTMLInputElement;
                const confirmPasswordInput = document.getElementById('confirm-password') as HTMLInputElement;

                if (!emailInput.value || !passwordInput.value || !confirmPasswordInput.value) {
                    alert('Please fill in all fields');
                    return;
                }

                if (passwordInput.value !== confirmPasswordInput.value) {
                    alert('Passwords do not match');
                    return;
                }

                try {
                    const response = await fetch(`${API_URL}/auth/register`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            email: emailInput.value,
                            password: passwordInput.value,
                        }),
                    });

                    if (response.ok) {
                        alert('Registration successful! Please sign in.');
                        window.location.href = '/login';
                    } else {
                        const error = await response.json();
                        alert(error.message || 'Registration failed.');
                    }
                } catch (error) {
                    console.error('Registration error:', error);
                    alert('An error occurred. Please try again later.');
                }
            });
        }
    </script>
</body>
</html>
