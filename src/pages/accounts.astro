---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Accounts">
    <main class="max-w-7xl mx-auto px-6 py-12">
        <!-- Header -->
        <header class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <h1 class="display-lg text-[#f7f8f8]">Accounts</h1>
                <p class="text-[18px] text-[#8a8f98] mt-2 font-[400]">Manage your financial institutions and wallets in one place.</p>
            </div>
            <div class="flex gap-3">
                <button class="btn-secondary" id="transfer-btn">
                    <i class="fas fa-exchange-alt mr-2 text-[10px]"></i> Transfer
                </button>
                <button class="btn-primary" id="add-account-btn">
                    <i class="fas fa-plus mr-2 text-[10px]"></i> Add Account
                </button>
            </div>
        </header>

        <!-- Accounts Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="accounts-grid">
            <!-- Loading State -->
            <div class="col-span-full py-24 text-center">
                <div class="inline-block animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-[#5e6ad2] mb-4"></div>
                <p class="text-[#8a8f98] font-[510]">Loading accounts...</p>
            </div>
        </div>
    </main>

    <!-- Account Modal -->
    <div id="account-modal" class="fixed inset-0 z-[100] hidden">
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
        <div class="absolute inset-0 flex items-center justify-center p-4">
            <div class="glass-card w-full max-w-md bg-[#0f1011] shadow-2xl animate-in fade-in zoom-in duration-200">
                <div class="p-6 border-b border-[rgba(255,255,255,0.05)] flex items-center justify-between">
                    <h2 class="text-xl font-[510] text-[#f7f8f8]" id="modal-title">Add Account</h2>
                    <button id="close-modal" class="text-[#8a8f98] hover:text-[#f7f8f8] transition-colors">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <form id="account-form" class="p-6 space-y-4">
                    <input type="hidden" id="account-id" name="id" />
                    <div>
                        <label for="name" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Account Name</label>
                        <input type="text" id="name" name="name" required
                            class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2 text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors"
                            placeholder="e.g. Main Checking" />
                    </div>
                    <div>
                        <label for="balance" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Initial Balance (EUR)</label>
                        <input type="number" id="balance" name="balance" step="0.01" required
                            class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2 text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors"
                            placeholder="0.00" value="0" />
                    </div>
                    <div class="pt-4 flex gap-3">
                        <button type="button" id="delete-account-btn" class="hidden px-4 py-2 text-rose-500 hover:bg-rose-500/10 rounded-md text-sm font-[510] transition-colors mr-auto">
                            Delete
                        </button>
                        <button type="button" id="cancel-modal" class="btn-secondary">Cancel</button>
                        <button type="submit" class="btn-primary">Save Account</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Transfer Modal -->
    <div id="transfer-modal" class="fixed inset-0 z-[100] hidden">
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
        <div class="absolute inset-0 flex items-center justify-center p-4">
            <div class="glass-card w-full max-w-md bg-[#0f1011] shadow-2xl animate-in fade-in zoom-in duration-200">
                <div class="p-6 border-b border-[rgba(255,255,255,0.05)] flex items-center justify-between">
                    <h2 class="text-xl font-[510] text-[#f7f8f8]">Transfer Funds</h2>
                    <button id="close-transfer-modal" class="text-[#8a8f98] hover:text-[#f7f8f8] transition-colors">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <form id="transfer-form" class="p-6 space-y-4">
                    <div class="relative">
                        <label for="from_account_id" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">From Account</label>
                        <input type="hidden" id="from_account_id" name="from" required />
                        <button type="button" id="from-account-trigger" 
                            class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2.5 text-[#f7f8f8] flex items-center justify-between focus:outline-none focus:border-[#5e6ad2] transition-colors group">
                            <span id="from-account-label" class="text-[#8a8f98]">Select origin</span>
                            <i class="fas fa-chevron-down text-[10px] text-[#62666d] group-hover:text-[#8a8f98] transition-colors"></i>
                        </button>
                        <div id="from-account-dropdown" class="absolute left-0 right-0 mt-2 bg-[#161718] border border-[rgba(255,255,255,0.08)] rounded-lg shadow-2xl hidden z-50 max-h-60 overflow-y-auto custom-scrollbar">
                            <div id="from-account-options" class="p-1.5 space-y-1"></div>
                        </div>
                    </div>
                    <div class="relative">
                        <label for="to_account_id" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">To Account</label>
                        <input type="hidden" id="to_account_id" name="to" required />
                        <button type="button" id="to-account-trigger" 
                            class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2.5 text-[#f7f8f8] flex items-center justify-between focus:outline-none focus:border-[#5e6ad2] transition-colors group">
                            <span id="to-account-label" class="text-[#8a8f98]">Select destination</span>
                            <i class="fas fa-chevron-down text-[10px] text-[#62666d] group-hover:text-[#8a8f98] transition-colors"></i>
                        </button>
                        <div id="to-account-dropdown" class="absolute left-0 right-0 mt-2 bg-[#161718] border border-[rgba(255,255,255,0.08)] rounded-lg shadow-2xl hidden z-50 max-h-60 overflow-y-auto custom-scrollbar">
                            <div id="to-account-options" class="p-1.5 space-y-1"></div>
                        </div>
                    </div>
                    <div>
                        <label for="transfer-amount" class="block text-[12px] font-[510] text-[#8a8f98] mb-1.5 uppercase tracking-wider">Amount (EUR)</label>
                        <input type="number" id="transfer-amount" name="amount" step="0.01" required
                            class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-md px-3 py-2 text-[#f7f8f8] focus:outline-none focus:border-[#5e6ad2] transition-colors"
                            placeholder="0.00" />
                    </div>
                    <div class="pt-4 flex gap-3">
                        <button type="button" id="cancel-transfer-modal" class="btn-secondary w-full">Cancel</button>
                        <button type="submit" class="btn-primary w-full">Confirm Transfer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        import type { Account } from "../types/account";

        const API_URL = import.meta.env.PUBLIC_API_URL; 

        // In-memory cache
        let accountsCache: Account[] | null = null;

        function getElements() {
            return {
                modal: document.getElementById('account-modal'),
                transferModal: document.getElementById('transfer-modal'),
                form: document.getElementById('account-form') as HTMLFormElement,
                transferForm: document.getElementById('transfer-form') as HTMLFormElement,
                modalTitle: document.getElementById('modal-title'),
                deleteBtn: document.getElementById('delete-account-btn'),
                addAccountBtn: document.getElementById('add-account-btn'),
                transferBtn: document.getElementById('transfer-btn'),
                fromTrigger: document.getElementById('from-account-trigger'),
                toTrigger: document.getElementById('to-account-trigger'),
                fromDropdown: document.getElementById('from-account-dropdown'),
                toDropdown: document.getElementById('to-account-dropdown'),
                fromLabel: document.getElementById('from-account-label'),
                toLabel: document.getElementById('to-account-label'),
                fromInput: document.getElementById('from_account_id') as HTMLInputElement,
                toInput: document.getElementById('to_account_id') as HTMLInputElement
            };
        }

        function openModal(account: Account | null = null) {
            const { modal, modalTitle, deleteBtn, form } = getElements();
            if (!modal || !modalTitle || !deleteBtn || !form) return;

            if (account) {
                modalTitle.textContent = 'Edit Account';
                (document.getElementById('account-id') as HTMLInputElement).value = account.id.toString();
                (document.getElementById('name') as HTMLInputElement).value = account.name;
                (document.getElementById('balance') as HTMLInputElement).value = (account.balance / 100).toString();
                deleteBtn.classList.remove('hidden');
            } else {
                modalTitle.textContent = 'Add Account';
                form.reset();
                (document.getElementById('account-id') as HTMLInputElement).value = '';
                deleteBtn.classList.add('hidden');
            }
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            const { modal, transferModal } = getElements();
            if (modal) modal.classList.add('hidden');
            if (transferModal) transferModal.classList.add('hidden');
            document.body.style.overflow = '';
        }

        function openTransferModal() {
            const { transferModal, transferForm, fromLabel, toLabel, fromInput, toInput } = getElements();
            if (!transferModal || !transferForm || !accountsCache) return;
            
            // Populate custom selects
            populateTransferDropdowns();

            // Reset labels and inputs
            if (fromLabel) {
                fromLabel.textContent = 'Select origin';
                fromLabel.classList.remove('text-[#f7f8f8]');
                fromLabel.classList.add('text-[#8a8f98]');
            }
            if (toLabel) {
                toLabel.textContent = 'Select destination';
                toLabel.classList.remove('text-[#f7f8f8]');
                toLabel.classList.add('text-[#8a8f98]');
            }
            if (fromInput) fromInput.value = '';
            if (toInput) toInput.value = '';

            transferForm.reset();
            transferModal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function populateTransferDropdowns() {
            const { fromDropdown, toDropdown, fromLabel, toLabel, fromInput, toInput } = getElements();
            if (!fromDropdown || !toDropdown || !accountsCache) return;

            const fromOptions = document.getElementById('from-account-options');
            const toOptions = document.getElementById('to-account-options');
            if (!fromOptions || !toOptions) return;

            const currencyFormatter = new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' });

            const createOptions = (container: HTMLElement, label: HTMLElement | null, input: HTMLInputElement | null, dropdown: HTMLElement | null) => {
                container.innerHTML = '';
                accountsCache!.forEach(acc => {
                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'w-full text-left px-3 py-2.5 rounded-md hover:bg-[rgba(255,255,255,0.05)] transition-colors flex items-center justify-between group';
                    btn.innerHTML = `
                        <div class="flex flex-col">
                            <span class="text-[14px] font-[510] text-[#f7f8f8]">${acc.name}</span>
                            <span class="text-[10px] text-[#62666d]">ID: ${acc.id}</span>
                        </div>
                        <span class="text-[13px] font-[510] text-[#8a8f98] group-hover:text-[#f7f8f8]">${currencyFormatter.format(acc.balance / 100)}</span>
                    `;
                    btn.onclick = () => {
                        if (input) input.value = acc.id.toString();
                        if (label) {
                            label.textContent = acc.name;
                            label.classList.remove('text-[#8a8f98]');
                            label.classList.add('text-[#f7f8f8]');
                        }
                        if (dropdown) dropdown.classList.add('hidden');
                    };
                    container.appendChild(btn);
                });
            };

            createOptions(fromOptions, fromLabel, fromInput, fromDropdown);
            createOptions(toOptions, toLabel, toInput, toDropdown);
        }

        async function handleTransfer(e: SubmitEvent) {
            e.preventDefault();
            const { transferForm, fromInput, toInput } = getElements();
            if (!transferForm) return;

            const formData = new FormData(transferForm);
            const data = {
                from: parseInt(fromInput?.value || ""),
                to: parseInt(toInput?.value || ""),
                amount: Math.round(parseFloat(formData.get('amount') as string) * 100)
            };

            if (!data.from || !data.to) {
                alert('Please select both accounts');
                return;
            }

            if (data.from === data.to) {
                alert('Origin and destination accounts must be different');
                return;
            }

            try {
                const response = await fetch(`${API_URL}/transfer`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data),
                    credentials: 'include'
                });

                if (!response.ok) throw new Error('Failed to complete transfer');
                
                accountsCache = null;
                await init();
                closeModal();
            } catch (error) {
                console.error('Transfer error:', error);
                alert('Failed to complete transfer');
            }
        }

        async function saveAccount(e: SubmitEvent) {
            e.preventDefault();
            const { form } = getElements();
            if (!form) return;
            const formData = new FormData(form);
            const id = formData.get('id');
            const data = {
                name: formData.get('name'),
                balance: Math.round(parseFloat(formData.get('balance') as string) * 100),
                is_active: "1"
            };

            const url = id ? `${API_URL}/account/${id}` : `${API_URL}/account`;
            const method = id ? 'PUT' : 'POST';

            try {
                const response = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data),
                    credentials: 'include'
                });

                if (!response.ok) throw new Error('Failed to save account');
                
                accountsCache = null;
                await init();
                closeModal();
            } catch (error) {
                console.error('Save error:', error);
                alert('Failed to save account');
            }
        }

        async function deleteAccount() {
            const id = (document.getElementById('account-id') as HTMLInputElement).value;
            if (!id || !confirm('Are you sure you want to delete this account?')) return;

            try {
                const response = await fetch(`${API_URL}/account/${id}`, {
                    method: 'DELETE',
                    credentials: 'include'
                });

                if (!response.ok) throw new Error('Failed to delete account');
                
                accountsCache = null;
                await init();
                closeModal();
            } catch (error) {
                console.error('Delete error:', error);
                alert('Failed to delete account');
            }
        }

        function renderAccounts(accounts: Account[]) {
            const grid = document.getElementById('accounts-grid');
            if (!grid) return;
            
            grid.innerHTML = '';

            const currencyFormatter = new Intl.NumberFormat('es-ES', { 
                style: 'currency', 
                currency: 'EUR' 
            });

            accounts.forEach((acc: Account) => {
                const card = document.createElement('div');
                card.className = 'glass-card p-6 flex flex-col hover:border-[rgba(255,255,255,0.15)] transition-all group cursor-pointer';
                card.onclick = () => openModal(acc);
                
                // Balance comes in cents from the API
                const balanceInDollars = acc.balance / 100;
                const isNegative = balanceInDollars < 0;
                const formattedBalance = currencyFormatter.format(Math.abs(balanceInDollars));

                card.innerHTML = `
                    <div class="flex items-start justify-between mb-6">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-lg flex items-center justify-center border border-[rgba(255,255,255,0.08)] bg-[rgba(255,255,255,0.03)]">
                                <i class="fas ${getIcon(acc.name)} text-[14px] text-[#d0d6e0]"></i>
                            </div>
                            <div>
                                <h3 class="text-[16px] font-[510] text-[#f7f8f8] group-hover:text-[#828fff] transition-colors">${acc.name}</h3>
                                <p class="text-[12px] text-[#62666d]">Account • ID: ${acc.id}</p>
                            </div>
                        </div>
                        <span class="badge-pill bg-[rgba(255,255,255,0.03)] text-[10px]">${acc.is_active === "1" ? 'Active' : 'Inactive'}</span>
                    </div>
                    
                    <div class="mt-auto">
                        <div class="text-[24px] font-[510] tracking-tight ${isNegative ? 'text-rose-500' : 'text-[#f7f8f8]'}">
                            ${isNegative ? '-' : ''}${formattedBalance}
                        </div>
                        <div class="flex items-center justify-between mt-4 pt-4 border-t border-[rgba(255,255,255,0.05)]">
                            <span class="text-[11px] text-[#62666d]">Created ${new Date(acc.created_at).toLocaleDateString()}</span>
                            <i class="fas fa-edit text-[10px] text-[#3e3e44] group-hover:text-[#8a8f98] transition-colors"></i>
                        </div>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        function getIcon(name: string) {
            const n = name.toLowerCase();
            if (n.includes('savings')) return 'fa-piggy-bank';
            if (n.includes('checking')) return 'fa-university';
            if (n.includes('investment') || n.includes('stock')) return 'fa-chart-line';
            if (n.includes('credit') || n.includes('card')) return 'fa-credit-card';
            return 'fa-wallet';
        }

        async function init() {
            if (accountsCache) {
                renderAccounts(accountsCache);
                return;
            }

            try {
                const response = await fetch(`${API_URL}/account`, {
                    credentials: 'include'
                });

                if (response.status === 401) {
                    window.location.href = '/login';
                    return;
                }

                if (!response.ok) throw new Error('Failed to fetch accounts');

                const accountsData: Account[] = await response.json();
                accountsCache = accountsData;
                renderAccounts(accountsData);
            } catch (error) {
                console.error('Fetch error:', error);
                const grid = document.getElementById('accounts-grid');
                if (grid && !accountsCache) {
                    grid.innerHTML = `
                        <div class="col-span-full py-24 text-center">
                            <p class="text-rose-500 font-[510]">Error loading accounts. Please try again later.</p>
                        </div>
                    `;
                }
            }
        }

        // Initialize on page load
        document.addEventListener('astro:page-load', () => {
            const { 
                addAccountBtn, transferBtn, closeModalBtn, cancelModalBtn, 
                closeTransferModalBtn, cancelTransferModalBtn, form, 
                transferForm, deleteAccountBtn, fromTrigger, toTrigger 
            } = {
                ...getElements(),
                closeModalBtn: document.getElementById('close-modal'),
                cancelModalBtn: document.getElementById('cancel-modal'),
                closeTransferModalBtn: document.getElementById('close-transfer-modal'),
                cancelTransferModalBtn: document.getElementById('cancel-transfer-modal'),
                deleteAccountBtn: document.getElementById('delete-account-btn')
            };

            init();

            addAccountBtn?.addEventListener('click', () => openModal());
            transferBtn?.addEventListener('click', openTransferModal);
            closeModalBtn?.addEventListener('click', closeModal);
            cancelModalBtn?.addEventListener('click', closeModal);
            closeTransferModalBtn?.addEventListener('click', closeModal);
            cancelTransferModalBtn?.addEventListener('click', closeModal);
            form?.addEventListener('submit', saveAccount);
            transferForm?.addEventListener('submit', handleTransfer);
            deleteAccountBtn?.addEventListener('click', deleteAccount);

            fromTrigger?.addEventListener('click', (e) => {
                e.stopPropagation();
                document.getElementById('from-account-dropdown')?.classList.toggle('hidden');
                document.getElementById('to-account-dropdown')?.classList.add('hidden');
            });

            toTrigger?.addEventListener('click', (e) => {
                e.stopPropagation();
                document.getElementById('to-account-dropdown')?.classList.toggle('hidden');
                document.getElementById('from-account-dropdown')?.classList.add('hidden');
            });

            document.addEventListener('click', (e) => {
                const { fromTrigger, toTrigger, fromDropdown, toDropdown } = getElements();
                if (!fromTrigger?.contains(e.target as Node) && !fromDropdown?.contains(e.target as Node)) {
                    fromDropdown?.classList.add('hidden');
                }
                if (!toTrigger?.contains(e.target as Node) && !toDropdown?.contains(e.target as Node)) {
                    toDropdown?.classList.add('hidden');
                }
            });
        });
    </script>
</Layout>
